<Window x:Class="CyberSecurityBotGUI1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber Security Awareness Assistant - POE Part 3"
        Height="680" 
        Width="960"
        WindowStartupLocation="CenterScreen"
        Background="#101820">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Chat Area -->
            <RowDefinition Height="110"/>
            <!-- Input + Control Buttons -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#00C2A8" Grid.Row="0" CornerRadius="5">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="CYBER SECURITY ASSISTANT"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Stay Safe Online • Task Assistant • Quiz • Activity Log"
                           Foreground="White"
                           FontSize="14"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- CHAT AREA -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="8,10,8,10">
            <TextBox x:Name="ChatArea"
                     Foreground="White"
                     FontSize="15.5"
                     TextWrapping="Wrap"
                     Background="#1E2A38"
                     BorderThickness="0"
                     IsReadOnly="True"
                     Padding="12"
                     VerticalScrollBarVisibility="Auto"/>
        </ScrollViewer>

        <!-- INPUT AREA + CONTROL BUTTONS -->
        <Grid Grid.Row="2" Margin="8,5,8,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Input Row -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>

                //===ADDED EXTRA DESIGN FEATURES=== 
                <TextBox x:Name="UserInput"
                         FontSize="16"
                         Margin="0,0,12,0"
                         Background="#1E2A38"
                         Foreground="White"
                         BorderBrush="#00C2A8"
                         BorderThickness="2"
                         Padding="10"
                         VerticalContentAlignment="Center"
                         KeyDown="UserInput_KeyDown"/>

                <Button Grid.Column="1"
                        Content="SEND"
                        FontSize="17"
                        FontWeight="Bold"
                        Background="#00C2A8"
                        Foreground="White"
                        Cursor="Hand"
                        BorderThickness="0"
                        Click="SendButton_Click"/>
            </Grid>

            <!-- Control Buttons -->
            <WrapPanel Grid.Row="1" Margin="0,12,0,0" HorizontalAlignment="Left">
                //===VIEW TASKS BUTTON===
                <Button Content="View Tasks" 
                        Width="130" Height="38" Margin="4"
                        Background="#2C3E50" Foreground="White"
                        FontWeight="Medium"
                        Click="ViewTasks_Click"/>

                 //===START QUIZ BUTTON==
                <Button Content="Start Quiz" 
                        Width="130" Height="38" Margin="4"
                        Background="#2C3E50" Foreground="White"
                        FontWeight="Medium"
                        Click="StartQuiz_Click"/>

                 //===ACTIVITY LOG BUTTON===
                <Button Content="Activity Log" 
                        Width="130" Height="38" Margin="4"
                        Background="#2C3E50" Foreground="White"
                        FontWeight="Medium"
                        Click="ActivityLog_Click"/>

                 //===CLEAR BUTTON===
                <Button Content="Clear Chat" 
                        Width="130" Height="38" Margin="4"
                        Background="#2C3E50" Foreground="White"
                        FontWeight="Medium"
                        Click="ClearChat_Click"/>
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
